{
  "extends": "@luna/tsconfig/base.json",
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020"],

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "esModuleInterop": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,

    "types": ["node"]
  },
  "include": ["./**/*.ts"],
  "exclude": ["node_modules", "./dist"]
}
