    "@luna/types": "workspace:*",
    "@luna/utils": "workspace:*",
    "@radix-ui/react-slot": "^1.0.2",
    "class-variance-authority": "^0.7.0",
    "@tanstack/react-query": "^5.90.2",
    "esbuild-plugin-svgr": "^3.1.1",
    "react-paginate": "^8.3.0",
    "tsup": "^8",
    "typescript": "^5"
  },
  "peerDependencies": {
    "@types/js-cookie": "^3.0.6",
    "clsx": "^2.1.1",
    "framer-motion": "^11.0.4",
    "js-cookie": "^3.0.5",
    "next": "^15.0.0",
    "next-intl": "^4.4.0",
    "tailwind-merge": "^3.3.1",
    "tailwindcss": "^4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "date-fns": "^4.1.0",
    "react-youtube": "^10.1.0",
    "react": "^19.0.0",
