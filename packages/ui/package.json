      "types": "./dist/core/client.d.ts",
      "import": "./dist/core/client.mjs",
      "require": "./dist/core/client.cjs"
    },
    "./common/client": {
      "types": "./dist/common/client.d.ts",
      "import": "./dist/common/client.mjs",
      "require": "./dist/common/client.cjs"
    },
    "./layout/client": {
      "types": "./dist/layout/client.d.ts",
      "import": "./dist/layout/client.mjs",
      "require": "./dist/layout/client.cjs"
    }
  },
  "files": [
    "dist"
