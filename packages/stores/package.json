{
  "name": "@luna/stores",
  "version": "0.0.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --dts --format esm,cjs --clean",
    "dev": "tsup src/index.ts --dts --format esm,cjs --watch"
  },
  "sideEffects": false,
  "devDependencies": {
    "@luna/eslint-config": "workspace:*",
    "@luna/tsconfig": "workspace:*",
    "@luna/types": "workspace:*",
    "@luna/utils": "workspace:*",
    "tsup": "^8",
    "typescript": "^5"
  },
  "peerDependencies": {
    "react": "*",
    "zustand": "*"
  }
}
