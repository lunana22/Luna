{
  "name": "@luna/types",
  "version": "0.0.0",
  "main": "./dist/index.cjs",
  "type": "module",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs",
      "types": "./dist/index.d.ts"
    },
    "./models": {
      "import": "./dist/models/index.js",
      "require": "./dist/models/index.cjs",
      "types": "./dist/models/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "lint": "eslint ."
  },
  "devDependencies": {
    "@luna/eslint-config": "workspace:*",
    "@luna/tsconfig": "workspace:*",
    "next-intl": "^4.5.8",
    "tsup": "^8",
    "typescript": "^5",
    "yup": "^0.32.2"
  }
}
