{
  "extends": "@luna/tsconfig/base.json",
  "compilerOptions": {
    "outDir": "dist",
    "declaration": true,
    "emitDeclarationOnly": false,
    "declarationMap": false,

    "isolatedDeclarations": false,
    "allowJs": false,
    "checkJs": false,
    "composite": false,
    "incremental": false,
    "tsBuildInfoFile": "./node_modules/.cache/ui.tsbuildinfo",

    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "target": "ES2020",
    "skipLibCheck": true,
    "strict": true,
    "baseUrl": ".",
    "paths": {
      "@luna/utils": ["../utils/src/index.ts"],
      "@luna/types": ["../types/src/index.ts"]
    }
  },
  "include": ["src"]
}
