{
  "compilerOptions": {
    // js 산출은 tsup이 하므로 여기서는 타입 해석 중심
    "composite": false,
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false, // tsup dts 사용, 굳이 true 필요 없음
    "rootDir": "src",
    "outDir": "dist",

    "moduleResolution": "bundler",
    "module": "ESNext",
    "target": "ES2020",
    "jsx": "react-jsx",

    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "strict": true,

    // 경로 별칭(선택)
    // "baseUrl": ".",
    // "paths": { "@api/*": ["src/*"] }
    "noEmit": true
  },
  "include": ["src/**/*"],
  "exclude": []
}
