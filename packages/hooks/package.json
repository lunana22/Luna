    "dev": "tsup --watch",
    "typecheck": "tsc -p tsconfig.build.json --noEmit"
  },
  "peerDependencies": {
    "react": "^18",
    "react-dom": "^18",
    "next": "^15.5.3",
    "react-hook-form": "^7.63.0"
  },
  "devDependencies": {
    "react": "^18",
    "react-dom": "^18",
    "typescript": "^5",
    "tsup": "^8",
    "@luna/eslint-config": "workspace:*",
    "@luna/tsconfig": "workspace:*",
    "@luna/utils": "workspace:*",
    "@luna/i18n": "workspace:*",
    "@luna/stores": "workspace:*",
    "@luna/types": "workspace:*",
    "@luna/queries": "workspace:*"
  },
  "dependencies": {
    "lodash": "^4.17.21",
    "date-fns": "^4.1.0",
    "@types/lodash": "^4.17.20"
  }
}
