{
  "name": "@luna/hooks",
  "type": "module",
  "version": "0.1.0",
  "files": [
    "dist"
  ],
  "exports": {
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.mjs"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.mjs"
    }
  },
  "sideEffects": false,
  "scripts": {
    "lint": "eslint .",
    "clean": "rm -rf dist",
